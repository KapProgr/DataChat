# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# LLM API Configuration (Groq or OpenAI-compatible)
LLM_API_KEY=your_api_key_here
LLM_MODEL=mixtral-8x7b-32768
LLM_BASE_URL=https://api.groq.com/openai/v1

# Optional: Clerk Authentication
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/datachat

# Application Settings
APP_NAME=DataChat API
ENVIRONMENT=development
DEBUG=false

# CORS Settings (set to your frontend URL in production)
FRONTEND_URL=http://localhost:3000

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=csv,xlsx,xls

# API Settings
API_TIMEOUT_SECONDS=30
MAX_ROWS_PER_ANALYSIS=100000
